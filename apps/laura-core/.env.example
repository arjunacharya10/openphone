# laura-core environment variables
# Copy to .env and set values

PORT=3000
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Gmail inbound via Cloud Pub/Sub (no sidecar needed)
#
# Setup (one-time):
#   1. gcloud auth application-default login
#   2. gcloud pubsub subscriptions create gmail-laura \
#        --topic=projects/<PROJECT>/topics/<TOPIC> \
#        --push-endpoint="" --ack-deadline=10
#   3. Set GMAIL_PUBSUB_SUBSCRIPTION below
#
# Full guide: docs/gmail-setup.md
GMAIL_PUBSUB_SUBSCRIPTION=projects/<project-id>/subscriptions/<subscription-id>

# Optional tuning
INBOUND_DEBOUNCE_MS=500
INBOUND_MAX_CONCURRENT=5

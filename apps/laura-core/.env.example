# laura-core environment variables
# Copy to .env and set values

PORT=3000
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Google / G Suite (set automatically by 'npm run setup google')
GOOGLE_APPLICATION_CREDENTIALS=~/.laura/google-credentials.json

# Gmail inbound via Cloud Pub/Sub (set automatically by 'npm run setup google pubsub')
GMAIL_PUBSUB_SUBSCRIPTION=projects/<project-id>/subscriptions/<subscription-id>

# Optional tuning
INBOUND_DEBOUNCE_MS=500
INBOUND_MAX_CONCURRENT=5

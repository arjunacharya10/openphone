# Run with: uv run python main.py  (uv handles the venv and Python version automatically)

# Kuzu graph database path (relative to working dir or absolute)
KUZU_DB=../openphone-core/context/memory/graph.kuzu

# Ollama LLM for entity extraction
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1:8b

# Ollama embedding model
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text

# Service port
PORT=7473

# Group ID scopes all episodes to one user/namespace
GROUP_ID=openphone
